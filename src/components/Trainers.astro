---
const trainers = [
  {
    name: "Carlos Mendoza",
    specialty: "CrossFit & Fuerza",
    certifications: "CrossFit L3, NSCA-CSCS",
    experience: "12 anos de experiencia",
    image: "https://images.unsplash.com/photo-1567013127542-490d483a84f4?w=500&q=80",
    bio: "Campeon nacional de CrossFit 2022. Especialista en programacion de fuerza y acondicionamiento.",
  },
  {
    name: "Ana Rivera",
    specialty: "Spinning & Cardio",
    certifications: "ACE-CPT, Schwinn Certified",
    experience: "8 anos de experiencia",
    image: "https://images.unsplash.com/photo-1594381898411-846e7d193883?w=500&q=80",
    bio: "Instructora certificada en ciclismo indoor. Sus clases de spinning son las mas demandadas del gym.",
  },
  {
    name: "Miguel Torres",
    specialty: "Boxing & MMA",
    certifications: "USA Boxing Coach, ISSA-CPT",
    experience: "15 anos de experiencia",
    image: "https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=500&q=80",
    bio: "Ex-boxeador profesional con 20 peleas invicto. Entrena desde principiantes hasta competidores.",
  },
  {
    name: "Lucia Paredes",
    specialty: "Yoga & Pilates",
    certifications: "RYT-500, PMA-CPT",
    experience: "10 anos de experiencia",
    image: "https://images.unsplash.com/photo-1518611012118-696072aa579a?w=500&q=80",
    bio: "Maestra en Hatha y Vinyasa Yoga. Especialista en rehabilitacion y flexibilidad funcional.",
  },
];
---

<section class="section section-alt" id="trainers">
  <div class="container">
    <div class="section-header">
      <span class="badge badge-red">EQUIPO PROFESIONAL</span>
      <h2>NUESTROS <span class="text-red">TRAINERS</span></h2>
      <span class="accent-line"></span>
      <p>Entrenadores certificados internacionalmente que te guiaran hacia tus objetivos.</p>
    </div>

    <div class="trainers-grid">
      {trainers.map((trainer) => (
        <div class="trainer-card">
          <div class="trainer-image">
            <img src={trainer.image} alt={trainer.name} loading="lazy" />
            <div class="trainer-overlay">
              <p class="trainer-bio">{trainer.bio}</p>
            </div>
          </div>
          <div class="trainer-info">
            <h3>{trainer.name}</h3>
            <span class="trainer-specialty">{trainer.specialty}</span>
            <p class="trainer-certs">{trainer.certifications}</p>
            <p class="trainer-exp">{trainer.experience}</p>
            <a href="#contacto" class="btn btn-primary trainer-btn">Reservar Sesion</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trainers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .trainer-card {
    background: #fff;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }

  .trainer-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hard);
  }

  .trainer-image {
    position: relative;
    height: 280px;
    overflow: hidden;
  }

  .trainer-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .trainer-card:hover .trainer-image img {
    transform: scale(1.05);
  }

  .trainer-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(220, 38, 38, 0.9), transparent);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .trainer-card:hover .trainer-overlay {
    opacity: 1;
  }

  .trainer-bio {
    color: #fff;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .trainer-info {
    padding: 1.25rem;
    text-align: center;
  }

  .trainer-info h3 {
    font-size: 1.4rem;
    color: var(--primary);
    margin-bottom: 0.25rem;
  }

  .trainer-specialty {
    display: block;
    color: var(--secondary);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .trainer-certs {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-bottom: 0.25rem;
  }

  .trainer-exp {
    font-size: 0.8rem;
    color: var(--text-light);
    margin-bottom: 1rem;
  }

  .trainer-btn {
    width: 100%;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
  }

  @media (max-width: 1024px) {
    .trainers-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .trainers-grid { grid-template-columns: 1fr; }
  }
</style>
