---
const plans = [
  {
    name: "Basico",
    price: "99",
    period: "/mes",
    features: [
      "Acceso a sala de pesas",
      "Acceso a sala de cardio",
      "Vestuarios y duchas",
      "2 clases grupales por semana",
      "Casillero diario",
    ],
    cta: "ELEGIR BASICO",
    popular: false,
    annualPrice: "79",
  },
  {
    name: "Pro",
    price: "149",
    period: "/mes",
    features: [
      "Todo del plan Basico",
      "Clases grupales ilimitadas",
      "Consulta con nutricionista mensual",
      "App de seguimiento y rutinas",
      "Zona funcional y CrossFit",
      "Casillero permanente",
      "Acceso a piscina",
    ],
    cta: "ELEGIR PRO",
    popular: true,
    annualPrice: "119",
  },
  {
    name: "Elite",
    price: "249",
    period: "/mes",
    features: [
      "Todo del plan Pro",
      "Personal Trainer 3x/semana",
      "Acceso a sauna y spa",
      "Suplementos basicos incluidos",
      "Plan nutricional personalizado",
      "Evaluacion corporal mensual",
      "Invitados gratis (2/mes)",
      "Estacionamiento preferencial",
    ],
    cta: "ELEGIR ELITE",
    popular: false,
    annualPrice: "199",
  },
];
---

<section class="section" id="planes">
  <div class="container">
    <div class="section-header">
      <span class="badge badge-red">MEMBRESIAS</span>
      <h2>ELIGE TU <span class="text-red">PLAN</span></h2>
      <span class="accent-line"></span>
      <p>Sin contratos largos. Cancela cuando quieras. Empieza tu transformacion hoy.</p>
    </div>

    <div class="plans-grid">
      {plans.map((plan) => (
        <div class={`plan-card ${plan.popular ? 'plan-popular' : ''}`}>
          {plan.popular && <div class="popular-badge">MAS POPULAR</div>}
          <div class="plan-annual-badge">
            <span class="badge badge-gold">Anual: S/ {plan.annualPrice}/mes</span>
          </div>
          <h3 class="plan-name">{plan.name}</h3>
          <div class="plan-price">
            <span class="currency">S/</span>
            <span class="amount">{plan.price}</span>
            <span class="period">{plan.period}</span>
          </div>
          <ul class="plan-features">
            {plan.features.map((feat) => (
              <li>
                <span class="check">&#10003;</span>
                {feat}
              </li>
            ))}
          </ul>
          <a href="#contacto" class={`btn ${plan.popular ? 'btn-primary' : 'btn-dark'} plan-cta`}>
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="plans-note text-center">
      * Todos los planes incluyen acceso los 7 dias de la semana. Descuento del 20% en planes anuales.
    </p>
  </div>
</section>

<style>
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .plan-card {
    background: #fff;
    border: 2px solid #e5e7eb;
    padding: 2.5rem 2rem;
    text-align: center;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
  }

  .plan-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-hard);
  }

  .plan-popular {
    border-color: var(--secondary);
    transform: scale(1.05);
    box-shadow: 0 10px 40px rgba(220, 38, 38, 0.15);
  }

  .plan-popular:hover {
    transform: scale(1.05) translateY(-6px);
  }

  .popular-badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--gradient-red);
    color: #fff;
    font-family: 'Bebas Neue', cursive;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    padding: 0.4rem 1.5rem;
  }

  .plan-annual-badge {
    margin-bottom: 1rem;
  }

  .plan-name {
    font-size: 2rem;
    color: var(--primary);
    margin-bottom: 0.5rem;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.15rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #f3f4f6;
  }

  .currency {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.5rem;
    color: var(--secondary);
  }

  .amount {
    font-family: 'Bebas Neue', cursive;
    font-size: 4rem;
    color: var(--primary);
    line-height: 1;
  }

  .period {
    font-size: 0.9rem;
    color: var(--text-light);
  }

  .plan-features {
    list-style: none;
    text-align: left;
    margin-bottom: 2rem;
  }

  .plan-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text);
    border-bottom: 1px solid #f3f4f6;
  }

  .check {
    color: var(--secondary);
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .plan-cta {
    width: 100%;
  }

  .plans-note {
    margin-top: 2rem;
    color: var(--text-light);
    font-size: 0.85rem;
  }

  @media (max-width: 900px) {
    .plans-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
    .plan-popular { transform: none; }
    .plan-popular:hover { transform: translateY(-6px); }
  }
</style>
