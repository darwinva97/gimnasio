---
const stories = [
  {
    name: "Rodrigo Castillo",
    age: 32,
    timeline: "3 meses",
    weightLost: "15 kg",
    muscleGained: "4 kg de musculo",
    quote: "Llegue sin poder subir escaleras sin cansarme. Hoy corro 10K sin parar. IronForge me dio la disciplina que necesitaba.",
    beforeImg: "https://images.unsplash.com/photo-1597347343908-2937e7dcc560?w=400&q=80",
    afterImg: "https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=400&q=80",
  },
  {
    name: "Valentina Rojas",
    age: 28,
    timeline: "6 meses",
    weightLost: "22 kg",
    muscleGained: "6 kg de musculo",
    quote: "El equipo de trainers me diseno un plan perfecto. Baje 22 kilos y gane una confianza que no sabia que existia.",
    beforeImg: "https://images.unsplash.com/photo-1508214751196-bcfd4ca60f91?w=400&q=80",
    afterImg: "https://images.unsplash.com/photo-1518611012118-696072aa579a?w=400&q=80",
  },
  {
    name: "Fernando Diaz",
    age: 45,
    timeline: "1 ano",
    weightLost: "35 kg",
    muscleGained: "10 kg de musculo",
    quote: "A los 45 pense que era imposible. Un ano despues competi en mi primer triatlon. Nunca es tarde para empezar.",
    beforeImg: "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?w=400&q=80",
    afterImg: "https://images.unsplash.com/photo-1567013127542-490d483a84f4?w=400&q=80",
  },
];
---

<section class="section section-dark">
  <div class="container">
    <div class="section-header">
      <span class="badge badge-gold">RESULTADOS REALES</span>
      <h2>HISTORIAS DE <span class="text-red">TRANSFORMACION</span></h2>
      <span class="accent-line"></span>
      <p>Nuestros miembros hablan por nosotros. Resultados reales, compromiso real.</p>
    </div>

    <div class="stories-grid">
      {stories.map((story) => (
        <div class="story-card">
          <div class="story-images">
            <div class="story-img before">
              <img src={story.beforeImg} alt={`${story.name} antes`} loading="lazy" />
              <span class="img-label">ANTES</span>
            </div>
            <div class="story-img after">
              <img src={story.afterImg} alt={`${story.name} despues`} loading="lazy" />
              <span class="img-label label-after">DESPUES</span>
            </div>
          </div>
          <div class="story-content">
            <div class="story-stats">
              <div class="story-stat">
                <span class="stat-val text-red">{story.weightLost}</span>
                <span class="stat-lbl">Perdidos</span>
              </div>
              <div class="story-stat">
                <span class="stat-val text-neon">{story.muscleGained}</span>
                <span class="stat-lbl">Ganados</span>
              </div>
              <div class="story-stat">
                <span class="stat-val text-gold">{story.timeline}</span>
                <span class="stat-lbl">Periodo</span>
              </div>
            </div>
            <blockquote class="story-quote">"{story.quote}"</blockquote>
            <div class="story-author">
              <strong>{story.name}</strong>
              <span>{story.age} anos - Miembro IronForge</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .story-card {
    background: #111827;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
    transition: transform 0.3s ease;
  }

  .story-card:hover {
    transform: translateY(-4px);
  }

  .story-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .story-img {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .story-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .img-label {
    position: absolute;
    bottom: 8px;
    left: 8px;
    background: rgba(0,0,0,0.7);
    color: #fff;
    font-family: 'Bebas Neue', cursive;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    padding: 0.2rem 0.6rem;
  }

  .label-after {
    background: var(--secondary);
  }

  .story-content {
    padding: 1.5rem;
  }

  .story-stats {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #1f2937;
  }

  .story-stat {
    text-align: center;
  }

  .stat-val {
    display: block;
    font-family: 'Bebas Neue', cursive;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .stat-lbl {
    font-size: 0.65rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .story-quote {
    font-size: 0.9rem;
    color: #d1d5db;
    line-height: 1.7;
    font-style: italic;
    margin-bottom: 1rem;
    border: none;
    padding: 0;
  }

  .story-author {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .story-author strong {
    color: #fff;
    font-size: 0.9rem;
  }

  .story-author span {
    color: #6b7280;
    font-size: 0.75rem;
  }

  @media (max-width: 900px) {
    .stories-grid { grid-template-columns: 1fr; max-width: 500px; margin: 0 auto; }
  }
</style>
