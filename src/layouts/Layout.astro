---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "IronForge - Centro Fitness | El Gym Más Completo de Lima",
  description = "Transforma tu cuerpo en IronForge, el centro fitness más completo de Lima. Equipos de última generación, entrenadores certificados y más de 50 clases semanales."
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
